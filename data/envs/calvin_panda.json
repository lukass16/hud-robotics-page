{
    "robot_type": "calvin_panda",
    "robot_class": "arm7g1",
    "control_rate": 30,
    "features": {
        "observation.images.rgb_static": {
            "role": "observation",
            "type": "rgb",
            "dtype": "uint8",
            "state_representation": "HWC",
            "shape": [200, 200, 3],
            "names": ["height", "width", "channel"],
            "stats": {"min": [[[0]], [[0]], [[0]]], "max": [[[255]], [[255]], [[255]]]},
            "comment": "Static scene camera (CALVIN default)."
        },
        "observation.images.rgb_gripper": {
            "role": "observation",
            "type": "rgb",
            "dtype": "uint8",
            "state_representation": "HWC",
            "shape": [84, 84, 3],
            "names": ["height", "width", "channel"],
            "stats": {"min": [[[0]], [[0]], [[0]]], "max": [[[255]], [[255]], [[255]]]},
            "comment": "Gripper-mounted RGB."
        },
        "observation.text": {
            "role": "observation",
            "type": "language",
            "dtype": "string",
            "comment": "Language annotation for long-horizon tasks."
        },
        "observation.state.robot_obs": {
            "role": "observation",
            "state_type": "EE_ABS_POS",
            "state_representation": "XYZ",
            "frame": "world",
            "dtype": "float32",
            "units": "m",
            "shape": [3],
            "order": "0-2",
            "names": ["tcp_pos.x", "tcp_pos.y", "tcp_pos.z"],
            "stats": {"mean": [], "std": [], "min": [], "max": []},
            "comment": "TCP position in world frame (robot_obs layout)."
        },
        "observation.state.tcp_euler": {
            "role": "observation",
            "state_type": "EE_ABS_ROT",
            "state_representation": "EULXYZ",
            "frame": "world",
            "dtype": "float32",
            "units": "rad",
            "shape": [3],
            "order": "3-5",
            "names": ["tcp_euler.rx", "tcp_euler.ry", "tcp_euler.rz"],
            "stats": {"mean": [], "std": [], "min": [], "max": []},
            "comment": "TCP orientation as euler XYZ (world)."
        },
        "observation.state.gripper_width": {
            "role": "observation",
            "state_type": "GRIPPER_ABS_POS",
            "state_representation": "REAL",
            "dtype": "float32",
            "units": "m",
            "shape": [1],
            "order": "6",
            "names": ["gripper_width"],
            "stats": {"mean": [], "std": [], "min": [], "max": []},
            "comment": "Gripper opening width (meters)."
        },
        "observation.state.arm_joint_pos": {
            "role": "observation",
            "state_type": "JOINT_ABS_POS",
            "state_representation": "REAL",
            "dtype": "float32",
            "units": "rad",
            "shape": [7],
            "order": "7-13",
            "names": [
                "joint_0", "joint_1", "joint_2", "joint_3",
                "joint_4", "joint_5", "joint_6"
            ],
            "stats": {"mean": [], "std": [], "min": [], "max": []},
            "comment": "7 arm joint positions (rad)."
        },
        "observation.state.gripper_action_state": {
            "role": "observation",
            "state_type": "GRIPPER_ABS_POS",
            "state_representation": "NORM11",
            "dtype": "float32",
            "units": "none",
            "shape": [1],
            "order": "14",
            "names": ["gripper_action"],
            "limits": {"min": [-1.0], "max": [1.0]},
            "stats": {"mean": [], "std": [], "min": [-1.0], "max": [1.0]},
            "comment": "Binary gripper state in robot_obs: close=-1, open=+1."
        },
        "action.rel_tcp_pos": {
            "role": "action",
            "state_type": "EE_DEL_POS",
            "state_representation": "XYZ",
            "frame": "world",
            "dtype": "float32",
            "units": "none",
            "shape": [3],
            "order": "0-2",
            "names": ["rel_tcp_pos.dx", "rel_tcp_pos.dy", "rel_tcp_pos.dz"],
            "limits": {"min": [-1.0, -1.0, -1.0], "max": [1.0, 1.0, 1.0]},
            "stats": {"mean": [], "std": [], "min": [-1.0, -1.0, -1.0], "max": [1.0, 1.0, 1.0]},
            "comment": "rel_actions pos: normalized delta, scale factor 50 in dataset."
        },
        "action.rel_tcp_euler": {
            "role": "action",
            "state_type": "EE_DEL_ROT",
            "state_representation": "EULXYZ",
            "frame": "world",
            "dtype": "float32",
            "units": "none",
            "shape": [3],
            "order": "3-5",
            "names": ["rel_tcp_euler.drx", "rel_tcp_euler.dry", "rel_tcp_euler.drz"],
            "limits": {"min": [-1.0, -1.0, -1.0], "max": [1.0, 1.0, 1.0]},
            "stats": {"mean": [], "std": [], "min": [-1.0, -1.0, -1.0], "max": [1.0, 1.0, 1.0]},
            "comment": "rel_actions orient: normalized delta, scale factor 20."
        },
        "action.gripper": {
            "role": "action",
            "state_type": "GRIPPER_ABS_POS",
            "state_representation": "NORM11",
            "dtype": "float32",
            "units": "none",
            "shape": [1],
            "order": "6",
            "names": ["gripper_action"],
            "limits": {"min": [-1.0], "max": [1.0]},
            "stats": {"mean": [], "std": [], "min": [-1.0], "max": [1.0]},
            "comment": "Binary gripper: close=-1, open=+1 (absolute in rel_actions vector)."
        }
    },
    "comment": "CALVIN Franka (PlayTable), 30 Hz. Default policy rel_actions 7-dim world-frame euler deltas + binary gripper."
}
